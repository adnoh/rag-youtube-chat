# DynaChat production secrets. Copy to .env and fill in values.
# .env is gitignored - NEVER commit the filled-in version.

# Supadata (YouTube transcripts) - https://supadata.ai
SUPADATA_API_KEY=

# Postgres (used by docker-compose AND the app)
POSTGRES_USER=dynachat
POSTGRES_PASSWORD=
POSTGRES_DB=dynachat
DATABASE_URL=postgresql://dynachat:REPLACE_WITH_POSTGRES_PASSWORD@127.0.0.1:5433/dynachat

# OpenRouter (RAG pipeline - embeddings + chat)
OPENROUTER_API_KEY=
